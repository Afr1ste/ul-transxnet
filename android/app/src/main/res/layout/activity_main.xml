<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TN5000 mainline · ORT deployment lab"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Three deployment tiers are built in: Fast / Accurate / Ensemble. Test-set mode reads TN5000_forReview/Annotations + JPEGImages + ImageSets/Main/test.txt, crops ROI on-device, and exports paper-ready metrics."
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvModelStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Model assets: checking..."
            android:textIsSelectable="true"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDatasetStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Dataset root: not selected" />

        <Button
            android:id="@+id/btnPickDatasetFolder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Select TN5000_forReview Folder" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Deployment mode"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbModeFast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fast" />

            <RadioButton
                android:id="@+id/rbModeAccurate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accurate" />

            <RadioButton
                android:id="@+id/rbModeEnsemble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ensemble" />

            <RadioButton
                android:id="@+id/rbModeGggMca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="GGG-MCA current" />

            <RadioButton
                android:id="@+id/rbModeGggMcaTta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GGG-MCA + HFlip TTA" />

            <RadioButton
                android:id="@+id/rbModeGggMcaEnsemble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GGG-MCA ensemble + TTA" />
        </RadioGroup>

        <TextView
            android:id="@+id/tvModeHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="-" />

        <Button
            android:id="@+id/btnApplyTrainingPreset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Apply training-aligned preset" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Expand ratio" />

            <EditText
                android:id="@+id/etExpandRatio"
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:ems="4"
                android:inputType="numberDecimal"
                android:text="0.30" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Threshold" />

            <EditText
                android:id="@+id/etThreshold"
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:ems="4"
                android:inputType="numberDecimal"
                android:text="0.61" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Temperature" />

            <EditText
                android:id="@+id/etTemperature"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:ems="6"
                android:inputType="numberDecimal"
                android:text="1.157835" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/cbSquareCrop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Square crop (desktop mainline usually keeps this OFF)" />

        <Button
            android:id="@+id/btnRunTestEval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:enabled="false"
            android:text="Run Test-Set Evaluation" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Paper batch collection"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Automatically run multiple cold/hot repeats per mode and save manifest / aggregate CSVs for the deployment section of the paper." />

        <CheckBox
            android:id="@+id/cbBatchFast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Include Fast" />

        <CheckBox
            android:id="@+id/cbBatchAccurate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include Accurate" />

        <CheckBox
            android:id="@+id/cbBatchEnsemble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include Ensemble" />

        <CheckBox
            android:id="@+id/cbBatchGggMca"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include GGG-MCA current" />

        <CheckBox
            android:id="@+id/cbBatchGggMcaTta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Include GGG-MCA + HFlip TTA" />

        <CheckBox
            android:id="@+id/cbBatchGggMcaEnsemble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Include GGG-MCA ensemble + TTA" />

        <CheckBox
            android:id="@+id/cbBatchMobileNetV3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include MobileNetV3" />

        <CheckBox
            android:id="@+id/cbBatchRepVit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include RepViT-M1.1" />

        <CheckBox
            android:id="@+id/cbBatchEfficientFormer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include EfficientFormer-L1" />

        <CheckBox
            android:id="@+id/cbBatchConvNeXt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include ConvNeXt-Tiny" />

        <CheckBox
            android:id="@+id/cbBatchSpeedCpuSweep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include GGG-MCA CPU/ONNX speed sweep" />

        <CheckBox
            android:id="@+id/cbBatchSpeedQuant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include GGG-MCA dynamic INT8" />

        <CheckBox
            android:id="@+id/cbBatchSpeedInput128"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include GGG-MCA input-128" />

        <CheckBox
            android:id="@+id/cbBatchSpeedXnnpack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include GGG-MCA XNNPACK-4T" />

        <CheckBox
            android:id="@+id/cbBatchSpeedNnapi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include GGG-MCA NNAPI plain" />

        <CheckBox
            android:id="@+id/cbBatchSpeedNnapiFp16"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Include GGG-MCA NNAPI FP16/NCHW" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cold runs / mode" />

            <EditText
                android:id="@+id/etColdRuns"
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:ems="3"
                android:inputType="number"
                android:text="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hot runs / mode" />

            <EditText
                android:id="@+id/etHotRuns"
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:ems="3"
                android:inputType="number"
                android:text="3" />
        </LinearLayout>

        <EditText
            android:id="@+id/etBatchNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Optional note (room temp / battery / build tag / comments)"
            android:inputType="textMultiLine"
            android:minLines="2" />

        <Button
            android:id="@+id/btnRunPaperBatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:enabled="false"
            android:text="Run Paper Batch" />

        <ProgressBar
            android:id="@+id/progressEval"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:max="1000"
            android:progress="0" />

        <TextView
            android:id="@+id/tvEvalProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Evaluation: idle" />

        <TextView
            android:id="@+id/tvEvalSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Summary: -"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/tvBatchSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Batch summary: -"
            android:textIsSelectable="true" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#333333" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Single-image debug"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Single-image mode intentionally uses center crop + resize, so it is a quick sanity check rather than a strict desktop-equivalent benchmark." />

        <Button
            android:id="@+id/btnPickImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Pick Image" />

        <Button
            android:id="@+id/btnRunInference"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:text="Run Inference" />

        <ImageView
            android:id="@+id/ivPreview"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginTop="16dp"
            android:adjustViewBounds="true"
            android:background="#222222"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tvImageStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Image: none" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Result will appear here."
            android:textIsSelectable="true"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLogits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="logits: -"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/tvProbabilities"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="probabilities: -"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/tvLatency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:text="latency: -"
            android:textIsSelectable="true" />

    </LinearLayout>
</ScrollView>
